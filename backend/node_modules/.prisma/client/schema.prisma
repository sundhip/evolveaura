datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  passwordHash  String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  profile       Profile?
  assessments   Assessment[]
  subjectScores SubjectScore[]
  quests        UserQuest[]
  xpLogs        XPLog[]
  achievements  UserAchievement[]
  detoxMetrics  DetoxMetric[]
  weeklyReports WeeklyReport[]
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  age             Int
  role            String // Student, JEE_Aspirant, NEET_Aspirant, College_Student, Professional
  academicDetails Json // { class?, stream?, semester?, degree? }
  primaryGoal     String // Study, Fitness, Mental_Wellness, Creativity, Balanced_Growth
  currentLevel    Int      @default(1)
  currentXP       Int      @default(0)
  currentStreak   Int      @default(0)
  lastActiveAt    DateTime @default(now())
  auraScore       Float    @default(0.0)
  auraRank        String   @default("E")
  avatar          String   @default("default_avatar")
  title           String   @default("Novice Evolver")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Assessment {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers      Json // JSON map of { questionId: score_1_to_5 }
  scholarScore Float
  warriorScore Float
  sageScore    Float
  creatorScore Float
  auraScore    Float
  auraRank     String
  completedAt  DateTime @default(now())
}

model SubjectScore {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectName    String
  understanding  Int      @default(50) // 0 - 100
  retention      Int      @default(50) // 0 - 100
  problemSolving Int      @default(50) // 0 - 100
  confidence     Int      @default(50) // 0 - 100
  updatedAt      DateTime @updatedAt

  @@unique([userId, subjectName])
}

model Quest {
  id          String      @id @default(uuid())
  title       String
  description String
  path        String // Scholar, Warrior, Sage, Creator
  difficulty  String // Easy, Medium, Hard, Elite
  xpReward    Int // 25, 50, 100, 250
  category    String // e.g., "Active Recall", "Walking", "Meditation", "Mind Maps"
  subSkill    String // e.g., "Focus", "Sleep", "Mindfulness", "Curiosity"
  userQuests  UserQuest[]
}

model UserQuest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  completed   Boolean   @default(false)
  completedAt DateTime?
}

model XPLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpGained  Int
  source    String // e.g., "Quest Completion", "Boss Battle", "Assessment"
  createdAt DateTime @default(now())
}

model Achievement {
  id               String            @id @default(uuid())
  name             String            @unique
  description      String
  requirementType  String // streak, level, path_rank, detox, focus, consistency
  requirementValue Int
  iconName         String
  users            UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

model DetoxMetric {
  id                     String   @id @default(uuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                   DateTime @db.Date
  screenTimeSeconds      Int      @default(0)
  studyTimeSeconds       Int      @default(0)
  exerciseTimeSeconds    Int      @default(0)
  mindfulnessTimeSeconds Int      @default(0)
  creationTimeSeconds    Int      @default(0)
  detoxScore             Int      @default(0) // calculated score (0 - 100)
  createdAt              DateTime @default(now())

  @@unique([userId, date])
}

model WeeklyReport {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate         DateTime @db.Date
  endDate           DateTime @db.Date
  averageDetoxScore Int
  focusMinutes      Int
  questsCompleted   Int
  rankProgress      Json // { scholarRank, warriorRank, sageRank, creatorRank }
  bottlenecks       Json // List of detected bottlenecks
  insights          String // AI/Psychology insight text
  createdAt         DateTime @default(now())
}
