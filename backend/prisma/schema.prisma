datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  passwordHash  String?
  googleId      String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  profile       Profile?
  assessments   Assessment[]
  subjectScores SubjectScore[]
  quests        UserQuest[]
  xpLogs        XPLog[]
  bossProgress  UserBossProgress[]
  projects      PersonalProject[]
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  role            String   // SCHOOL_CLASS_1 ... SCHOOL_CLASS_12, JES_ASPIRANT, NEET_ASPIRANT, COLLEGE_STUDENT, PROFESSIONAL
  primaryGoal     String
  currentLevel    Int      @default(1)
  currentXP       Int      @default(0)
  auraShields     Int      @default(0) // Streak protection count
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActiveAt    DateTime @default(now())
  auraScore       Float    @default(0.0)
  auraRank        String   @default("E")
  avatar          String   @default("default_avatar")
  equippedTitle   String   @default("Novice Evolver")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Assessment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers       Json
  scholarScore  Float
  warriorScore  Float
  sageScore     Float
  creatorScore  Float
  auraScore     Float
  auraRank      String
  bottleneck    String
  completedAt   DateTime @default(now())
}

model SubjectScore {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectName      String
  understanding    Int      @default(50)
  retention        Int      @default(50)
  problemSolving   Int      @default(50)
  confidence       Int      @default(50)
  updatedAt        DateTime @updatedAt

  @@unique([userId, subjectName])
}

model Quest {
  id               String      @id @default(uuid())
  title            String
  description      String
  path             String      // SCHOLAR, WARRIOR, SAGE, CREATOR, MAIN, BOSS, BONUS
  difficulty       String      // EASY, MEDIUM, HARD, ELITE
  xpReward         Int
  verificationType String      // TIMER, WALKING, REFLECTION, ACTION
  userQuests       UserQuest[]
}

model UserQuest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  completed   Boolean   @default(false)
  completedAt DateTime?
  inputData   String?
}

model Boss {
  id          String             @id @default(uuid())
  name        String             @unique
  description String
  maxHP       Int
  badgeReward String
  xpReward    Int
  spriteName  String
  userBosses  UserBossProgress[]
}

model UserBossProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bossId      String
  boss        Boss      @relation(fields: [bossId], references: [id], onDelete: Cascade)
  currentHP   Int
  defeated    Boolean   @default(false)
  unlockedAt  DateTime  @default(now())
  defeatedAt  DateTime?
}

model PersonalProject {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  progress  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model XPLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpGained  Int
  source    String
  createdAt DateTime @default(now())
}
