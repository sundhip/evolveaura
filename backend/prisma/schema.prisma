datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  passwordHash  String?
  googleId      String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  profile       Profile?
  assessments   Assessment[]
  subjectScores SubjectScore[]
  quests        UserQuest[]
  xpLogs        XPLog[]
  bossProgress  UserBossProgress[]
  projects      PersonalProject[]
  shadows       ShadowSoldier[]
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  role            String   // SCHOOL_CLASS_1 ... SCHOOL_CLASS_12, JES_ASPIRANT, NEET_ASPIRANT, COLLEGE_STUDENT, PROFESSIONAL
  primaryGoal     String
  currentLevel    Int      @default(1)
  currentXP       Int      @default(0)
  auraShields     Int      @default(0) // Streak protection count
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActiveAt    DateTime @default(now())
  auraScore       Float    @default(0.0)
  auraRank        String   @default("E")
  avatar          String   @default("default_avatar")
  equippedTitle   String   @default("Novice Evolver")
  statINT         Int      @default(10)
  statSTR         Int      @default(10)
  statVIT         Int      @default(10)
  statWIS         Int      @default(10)
  statAGI         Int      @default(10)
  unallocatedPoints Int    @default(0)
  lastHydratedAt  DateTime?
  lastQuestRollDate String?
  integrityScore  Float    @default(100.0)
  pressureScore   Int      @default(0)
  stabilityScore  Float    @default(100.0)
  recoveryModeActive Boolean @default(false)
  cooldownActive  Boolean  @default(false)
  cooldownEndsAt  DateTime?
  fatigueActive   Boolean  @default(false)
  fatigueEndsAt   DateTime?
  levelLocked     Boolean  @default(false)
  examActive      Boolean  @default(false)
  examChallengeStartedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Assessment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers       Json
  scholarScore  Float
  warriorScore  Float
  sageScore     Float
  creatorScore  Float
  auraScore     Float
  auraRank      String
  bottleneck    String
  completedAt   DateTime @default(now())
}

model SubjectScore {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectName      String
  understanding    Int      @default(50)
  retention        Int      @default(50)
  problemSolving   Int      @default(50)
  confidence       Int      @default(50)
  updatedAt        DateTime @updatedAt

  @@unique([userId, subjectName])
}

model Quest {
  id               String      @id @default(uuid())
  title            String
  description      String
  path             String      // SCHOLAR, WARRIOR, SAGE, CREATOR, MAIN, BOSS, BONUS
  difficulty       String      // EASY, MEDIUM, HARD, ELITE
  xpReward         Int
  verificationType String      // TIMER, WALKING, REFLECTION, ACTION
  userQuests       UserQuest[]
  shadowSoldiers   ShadowSoldier[]
}

model UserQuest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  completed   Boolean   @default(false)
  completedAt DateTime?
  inputData   String?
  timerStartedAt DateTime?
  proofType   String?
  isHighTier  Boolean   @default(false)
}

model Boss {
  id          String             @id @default(uuid())
  name        String             @unique
  description String
  maxHP       Int
  badgeReward String
  xpReward    Int
  spriteName  String
  isRecovery  Boolean            @default(false)
  userBosses  UserBossProgress[]
}

model UserBossProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bossId      String
  boss        Boss      @relation(fields: [bossId], references: [id], onDelete: Cascade)
  currentHP      Int
  defeated       Boolean   @default(false)
  selectedTier   Int       @default(0) // 0 = none, 1 = Minor Quantum, 2 = Apex Titan, 3 = Void Overlord
  questActive    Boolean   @default(false)
  questCompleted Boolean   @default(false)
  unlockedAt     DateTime  @default(now())
  defeatedAt     DateTime?
}

model PersonalProject {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  progress  Float    @default(0)
  isDungeon Boolean  @default(false)
  currentFloor Int   @default(1)
  floor1Title String?
  floor1Completed Boolean @default(false)
  floor2Title String?
  floor2Completed Boolean @default(false)
  floor3Title String?
  floor3Completed Boolean @default(false)
  dungeonCompleted Boolean @default(false)
  rewardClaimed Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model XPLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpGained  Int
  source    String
  createdAt DateTime @default(now())
}

model UserQuestStreak {
  id             String   @id @default(uuid())
  userId         String
  questId        String
  streak         Int      @default(0)
  lastCompletedAt DateTime?
  @@unique([userId, questId])
}

model VerificationSession {
  id             String   @id @default(uuid())
  userId         String
  userQuestId    String?
  challengeCode  String
  challengeType  String
  issuedAt       DateTime @default(now())
  expiresAt      DateTime
  captureMode    String   // "IMAGE" or "VIDEO"
  ocrResult      String?
  objectResult   String?
  manualTextInput String?
  confidenceScore Float?
  decision       String   // "PASS", "RETRY", "FAIL", "FLAGGED"
}

model ShadowSoldier {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  title     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Duel {
  id             String   @id @default(uuid())
  challengerId   String
  opponentId     String
  durationHours  Int
  status         String   // "PENDING", "ACTIVE", "COMPLETED", "DECLINED"
  startTime      DateTime?
  endTime        DateTime?
  challengerXP   Int      @default(0)
  opponentXP     Int      @default(0)
  challengerStance String? // "BERSERKER", "FOCUS", "NONE"
  opponentStance   String? // "BERSERKER", "FOCUS", "NONE"
  createdAt      DateTime @default(now())
}
